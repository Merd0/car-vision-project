# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Jupyter / notebooks
.ipynb_checkpoints/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Environment and local overrides
.env
.env.*
!.env.example

# Logs
*.log

# Downloaded datasets and scraped images
car_vision_project/data/*/
car_vision_project/data/**/*.jpg
car_vision_project/data/**/*.jpeg
car_vision_project/data/**/*.png
car_vision_project/data/**/*.webp
car_vision_project/data/**/*.bmp
!car_vision_project/data/.gitkeep
!car_vision_project/data/*.py

# Training artifacts
car_vision_project/artifacts/*
!car_vision_project/artifacts/.gitkeep
!car_vision_project/artifacts/classes.txt

# Model weights anywhere
*.pth
*.pt
*.ckpt
*.onnx

# Temporary files
tmp/
temp/
*.tmp
