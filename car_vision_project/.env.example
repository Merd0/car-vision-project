# Runtime environment
APP_ENV=production
LOG_LEVEL=info

# API server
API_HOST=0.0.0.0
API_PORT=8000
UVICORN_WORKERS=1
CORS_ALLOWED_ORIGINS=

# Model runtime
# Use paths relative to the repository root when running locally.
MODEL_CHECKPOINT_PATH=car_vision_project/artifacts/best_car_model.pth
MODEL_CLASSES_PATH=car_vision_project/artifacts/classes.txt
MODEL_NUM_CLASSES=105
MODEL_IMAGE_SIZE=224
MODEL_DEVICE=auto
MODEL_DROPOUT=0.3

# Template and static asset directories
TEMPLATES_DIR=car_vision_project/templates
STATIC_DIR=car_vision_project/static

# Mock service/database placeholders
MOCK_DB_URL=mock://local-car-market
FEATURE_SERVICE_TIMEOUT_SECONDS=2
VALUATION_SERVICE_TIMEOUT_SECONDS=2

# Security and upload limits
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_CONTENT_TYPES=image/jpeg,image/png,image/webp
